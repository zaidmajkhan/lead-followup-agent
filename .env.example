# Copy this file to .env and fill in your values.

# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Claude model to use (default: claude-sonnet-4-6)
MODEL=claude-sonnet-4-6

# Optional: max tokens for each generated email (default: 512)
MAX_TOKENS=512

# Optional: the sign-off used at the end of every email.
SIGNATURE_NAME=The Team

# Optional: your company name, used in the subject line.
COMPANY_NAME=

# Optional: seconds to wait between sends to avoid rate limits (default: 1.0)
SEND_DELAY_SECONDS=1.0
